{
    "name": "akunbeben/inline-confirm",
    "description": "Inline confirmation for Filament Actions",
    "keywords": [
        "akunbeben",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "inline-confirm"
    ],
    "homepage": "https://github.com/akunbeben/inline-confirm",
    "support": {
        "issues": "https://github.com/akunbeben/inline-confirm/issues",
        "source": "https://github.com/akunbeben/inline-confirm"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Benny Rahmat",
            "email": "akunbeben@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Akunbeben\\InlineConfirm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Akunbeben\\InlineConfirm\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run",
        "ide": "@php bin/ide.php"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Akunbeben\\InlineConfirm\\InlineConfirmServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
